# ─── Local development (non-Docker) ──────────────────────────────────────────
# Copy this file to `.env` for local development:
#   cp .env.example .env
# For Docker Compose you do NOT need this file — the compose stack sets
# DATABASE_URL automatically (the DB is reachable at the `db` service hostname).

# PostgreSQL connection used by Prisma (local Postgres on the host).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kraken_trading_simulator?schema=public"

# Optional: override the demo user created by `npm run seed`.
SEED_USER_EMAIL=demo@kraken-simulator.local
SEED_USER_PASSWORD=demo123456
SEED_USER_NAME=Demo Trader
SEED_USER_BALANCE=10000
